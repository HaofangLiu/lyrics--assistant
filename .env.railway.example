# Backend service variables
RECOGNITION_PROVIDER=acrcloud
ACRCLOUD_HOST=identify-cn-north-1.acrcloud.cn
ACRCLOUD_ACCESS_KEY=
ACRCLOUD_ACCESS_SECRET=

DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=deepseek-v4-flash

# 防滥用：后端是公网可达的付费代理，务必启用。
# APP_ACCESS_TOKEN 自己生成一段随机串（如 openssl rand -hex 24），
# 前端 VITE_APP_TOKEN 必须填同一个值。
APP_ACCESS_TOKEN=
RATE_LIMIT_PER_MIN=30

# 首次部署可临时用 *，拿到前端域名后立刻改成精确的前端 URL，例如：
# CORS_ALLOW_ORIGINS=https://your-frontend.up.railway.app
CORS_ALLOW_ORIGINS=https://your-frontend.up.railway.app

# Frontend service variable
# Replace with the generated backend public domain plus /api.
VITE_API_BASE_URL=https://your-backend.up.railway.app/api
# 必须与 backend 的 APP_ACCESS_TOKEN 完全一致
VITE_APP_TOKEN=
